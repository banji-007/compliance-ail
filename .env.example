# Environment Variables Template
# Copy this file to .env and fill in your actual values

# OpenAI API Key for LLM interactions
OPENAI_API_KEY=your_openai_api_key_here

# ImmuDB Credentials for cryptographic ledger
IMMUDB_USER=immudb
IMMUDB_PASSWORD=immudb

# Optional: Custom ImmuDB connection settings
# IMMUDB_HOST=localhost
# IMMUDB_PORT=3322
# IMMUDB_DATABASE=defaultdb

# Optional: Custom OPA endpoint (production environments)
# OPA_URL=https://localhost:8443/v1/data/ail/policy

# SPIFFE Workload API endpoint for SVID fetching
SPIFFE_ENDPOINT_SOCKET=unix:///tmp/spire-sockets/workload_api.sock

# --- Compliance Pack Selection ---
# Set to 'true' to arm a framework on boot. The policy-bootstrapper init
# container stages only enabled packs into /policy/active before OPA starts.
# At least one pack must be enabled — all disabled is rejected at startup.
ENABLE_GDPR=true
ENABLE_SOC2=true
ENABLE_FINOPS=true
ENABLE_HIPAA=false
